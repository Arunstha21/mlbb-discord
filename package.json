{
	"name": "dot-tournament-bot",
	"version": "0.1.0",
	"description": "A Discord bot to facilitate organising Challonge tournaments and verify submitted decks.",
	"private": true,
	"scripts": {
		"dev": "NODE_NO_WARNINGS=1 nodemon --watch .env -e ts,env --exec ts-node src/index.ts",
		"start": "node --enable-source-maps --no-deprecation dist/index.js",
		"test": "nyc mocha --config test/.mocharc.yml test/*.ts test/**/*.unit.ts",
		"cover": "nyc report",
		"lint": "eslint src",
		"build": "shx rm -f tsconfig.tsbuildinfo && tsc && shx rm -rf dist/web/views dist/web/public && shx mkdir -p dist/web && shx cp -r src/web/views dist/web/views && shx cp -r src/web/public dist/web/public",
		"electron:dev": "electron ./dist/electron/main.js",
		"electron:build": "tsc -p electron/tsconfig.json && tsc -p ui/tsconfig.json",
		"build:win": "npm run build && npm run electron:build && electron-builder --win",
		"build:mac": "npm run build && npm run electron:build && electron-builder --mac",
		"build:all": "npm run build && npm run electron:build && electron-builder --win --mac"
	},
	"main": "dist/electron/main.js",
	"build": {
		"appId": "com.mlbb.tournament-bot",
		"productName": "MLBB Tournament Bot",
		"directories": {
			"output": "dist/installers",
			"buildResources": "assets"
		},
		"files": [
			"dist/electron/**/*",
			"dist/**/*",
			"!dist/installers/**",
			"ui/**/*",
			"data/**/*"
		],
		"extraResources": [
			{
				"from": "node_modules",
				"to": "app/node_modules",
				"filter": [
					"call-bind-apply-helpers/**/*",
					"call-bound/**/*",
					"es-errors/**/*",
					"function-bind/**/*",
					"get-intrinsic/**/*",
					"hasown/**/*"
				]
			}
		],
		"asar": false,
		"win": {
			"target": "nsis",
			"icon": "assets/icon.ico"
		},
		"mac": {
			"target": "dmg",
			"icon": "assets/icon.icns",
			"category": "public.app-category.utilities"
		},
		"nsis": {
			"oneClick": false,
			"allowToChangeInstallationDirectory": true,
			"createDesktopShortcut": true,
			"createStartMenuShortcut": true
		}
	},
	"author": "Arun Shrestha",
	"license": "AGPL-3.0-or-later",
	"engines": {
		"node": ">=24",
		"npm": ">=10"
	},
	"dependencies": {
		"@fast-csv/format": "^5.0.5",
		"async-mutex": "^0.5.0",
		"call-bind-apply-helpers": "^1.0.2",
		"debug": "^4.4.3",
		"es-errors": "^1.3.0",
		"function-bind": "^1.1.2",
		"discord.js": "^14.25.1",
		"dotenv": "^17.3.1",
		"ejs": "^5.0.1",
		"express": "^5.2.1",
		"express-ejs-layouts": "^2.5.1",
		"make-fetch-happen": "^15.0.4",
		"pg": "^8.20.0",
		"reflect-metadata": "^0.2.2",
		"sql.js": "^1.12.0",
		"supports-color": "^10.2.2",
		"typeorm": "^0.3.28"
	},
	"devDependencies": {
		"@alphakretin/essentials": "^6.2.0",
		"@alphakretin/mocha-ecosystem": "^1.1.0",
		"@testcontainers/postgresql": "^10.28.0",
		"@types/debug": "^4.1.12",
		"@types/express": "^5.0.6",
		"@types/express-ejs-layouts": "^2.5.4",
		"@types/make-fetch-happen": "^10.0.4",
		"@types/sql.js": "^1.4.9",
		"electron": "^35.0.0",
		"electron-builder": "^25.1.8",
		"mocha": "^11.7.5",
		"nodemon": "^3.1.14",
		"shx": "^0.3.4"
	},
	"eslintConfig": {
		"extends": "@alphakretin"
	},
	"prettier": "@alphakretin/essentials",
	"nyc": {
		"extends": "@alphakretin/mocha-ecosystem"
	},
	"overrides": {
		"glob": "^11.1.0",
		"rimraf": "^6.0.1",
		"tar": "^7.4.3",
		"uuid": "^11.0.3"
	}
}
