# Discord Bot Configuration
DISCORD_TOKEN=your_discord_bot_token_here

# Challonge API Credentials
CHALLONGE_USERNAME=your_challonge_username
CHALLONGE_TOKEN=your_challonge_api_token

# Bot Configuration
DOT_DEFAULT_PREFIX=dot!
DOT_DEFAULT_TO_ROLE=TO

# Database Configuration
# Choose ONE of the following:

# For SQLite (recommended for development/small deployments)
SQLITE_DB=./data/dot.db

# For PostgreSQL (recommended for production/larger deployments)
# POSTGRESQL_URL=postgresql://user:password@localhost:5432/dbname

# Optional: Logging Webhook
DOT_LOGGER_WEBHOOK=your_discord_webhook_url_for_logs

# Optional: Git revision info
DOT_REVISION=dev
