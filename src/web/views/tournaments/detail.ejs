<div class="tournament-detail-page">
	<div class="page-header">
		<div>
			<div class="header-breadcrumbs">
				<a href="/tournaments">Tournaments</a> / <span id="header-id"><%= tournamentId %></span>
			</div>
			<h2 class="page-title" id="t-name">Loading...</h2>
			<div class="header-meta" style="margin-top: 8px; display: flex; gap: 8px; align-items: center;">
				<span id="t-status-badge" class="badge">...</span>
				<span id="t-format" style="color: var(--text-secondary); font-size: 14px;">...</span>
			</div>
		</div>
		<div class="header-actions">
			<button class="btn btn-secondary" onclick="window.location.href='/tournaments'">Back to List</button>
		</div>
	</div>

	<!-- Info Section -->
	<div class="info-grid">
		<div class="info-card">
			<div class="info-label">Discord Server ID</div>
			<div class="info-value" id="t-server">&mdash;</div>
		</div>
		<div class="info-card">
			<div class="info-label">Capacity</div>
			<div class="info-value" id="t-capacity">&mdash;</div>
		</div>
		<div class="info-card">
			<div class="info-label">Verified Teams</div>
			<div class="info-value" id="t-verified-count" style="color: var(--success);">&mdash;</div>
		</div>
		<div class="info-card">
			<div class="info-label">Unverified Teams</div>
			<div class="info-value" id="t-unverified-count" style="color: var(--warning);">&mdash;</div>
		</div>
	</div>

	<!-- Tabs Container -->
	<div class="detail-tabs" style="display: flex; justify-content: space-between; align-items: center;">
		<div style="display: flex; gap: 16px;">
			<button class="tab-btn active" data-tab="participants" onclick="switchTab('participants')">
				Participants (<span id="t-p-count">0</span>)
			</button>
			<button class="tab-btn" data-tab="schedules" onclick="switchTab('schedules')">
				Schedules (<span id="t-s-count">0</span>)
			</button>
		</div>
		<div style="display: flex; gap: 12px;">
			<button class="btn btn-primary" id="btn-start-round" onclick="openStartRoundModal()">
				<span class="btn-icon">
					<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"/></svg>
				</span>
				Start Round
			</button>
			<button class="btn btn-primary" id="btn-sync" onclick="syncTournament()">
				<span class="btn-icon">
					<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 2v6h-6"/><path d="M3 12a9 9 0 0 1 15-6.7L21 8"/><path d="M3 22v-6h6"/><path d="M21 12a9 9 0 0 1-15 6.7L3 16"/></svg>
				</span>
				Sync from Challonge
			</button>
		</div>
	</div>

	<!-- Panes -->
	<div class="tab-pane active" id="pane-participants">
		<div class="pane-actions">
			<button class="btn btn-secondary" onclick="openParticipantModal()">
				<span class="btn-icon"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5v14"/></svg></span> Add Participant
			</button>
			<button class="btn btn-primary" onclick="openCSVImportModal('participants')">
				<span class="btn-icon"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg></span> Import CSV
			</button>
			<button class="help-link" style="background: none; border: none; padding: 0;" onclick="openCSVFormatModal('participants')">CSV Format Guide</button>
		</div>
		<div class="table-container">
			<table class="table">
				<thead>
					<tr>
						<th>Team Name</th>
						<th>Captain Name</th>
						<th>Email</th>
						<th>Discord</th>
						<th>Challonge ID</th>
						<th>Verified</th>
						<th class="actions-col">Actions</th>
					</tr>
				</thead>
				<tbody id="participants-body">
					<tr><td colspan="7" class="loading-row"><div class="spinner"></div> Loading participants...</td></tr>
				</tbody>
			</table>
		</div>
	</div>

	<div class="tab-pane" id="pane-schedules">
		<div class="pane-actions">
			<button class="btn btn-secondary" onclick="openScheduleModal()">
				<span class="btn-icon"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5v14"/></svg></span> Add Schedule
			</button>
			<button class="btn btn-primary" onclick="openCSVImportModal('schedules')">
				<span class="btn-icon"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg></span> Import CSV
			</button>
			<button class="help-link" style="background: none; border: none; padding: 0;" onclick="openCSVFormatModal('schedules')">CSV Format Guide</button>
		</div>
		<div class="table-container">
			<table class="table">
				<thead>
					<tr>
						<th>Match</th>
						<th>Round</th>
						<th>Teams</th>
						<th>Scheduled Time</th>
						<th>Thread ID</th>
						<th>Notified</th>
						<th class="actions-col">Actions</th>
					</tr>
				</thead>
				<tbody id="schedules-body">
					<tr><td colspan="7" class="loading-row"><div class="spinner"></div> Loading schedules...</td></tr>
				</tbody>
			</table>
		</div>
	</div>
</div>

<!-- CSV Import Modal -->
<div id="csv-import-modal" class="modal-overlay" style="display: none;" onclick="if(event.target === this) closeCSVImportModal()">


	<div class="modal modal-large">
		<div class="modal-header">
			<h3 id="csv-modal-title" class="modal-title">Import from CSV</h3>
			<button class="modal-close" onclick="closeCSVImportModal()">&times;</button>
		</div>
		<div class="modal-body">
			<!-- Upload Section -->
			<div id="csv-upload-section">
				<div id="csv-dropzone" class="csv-dropzone">
					<input type="file" id="csv-file-input" accept=".csv" style="display: none;" onchange="handleCSVFileSelect(event)">
					<div class="dropzone-content">
						<div class="dropzone-icon"><svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--text-secondary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="18" x2="12" y2="12"/><polyline points="9 15 12 12 15 15"/></svg></div>
						<p class="dropzone-text">Drag & drop your CSV file here</p>
						<p class="dropzone-subtext">or click to browse</p>
						<button class="btn btn-secondary btn-sm" onclick="document.getElementById('csv-file-input').click()">Choose File</button>
					</div>
				</div>
				<div id="csv-file-info" class="csv-file-info" style="display: none;">
					<div class="file-info-item">
						<span class="file-info-icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg></span>
						<div class="file-info-details">
							<div class="file-info-name" id="csv-file-name">filename.csv</div>
							<div class="file-info-size" id="csv-file-size">0 KB</div>
						</div>
						<button class="file-info-remove" onclick="clearCSVFile()">&times;</button>
					</div>
				</div>
			</div>

			<!-- Options Section -->
			<div id="csv-options-section" class="csv-options-section" style="display: none;">
				<div class="form-group">
					<label class="checkbox-label">
						<input type="checkbox" id="csv-register-challonge">
						<span>Register participants to Challonge</span>
					</label>
					<p class="help-text">Automatically create Challonge participants for imported players</p>
				</div>
			</div>

			<!-- Preview Section -->
			<div id="csv-preview-section" class="csv-preview-section" style="display: none;">
				<h4>Preview (<span id="csv-preview-count">0</span> rows)</h4>
				<div class="table-container table-preview">
					<table class="table table-sm">
						<thead id="csv-preview-thead"></thead>
						<tbody id="csv-preview-tbody"></tbody>
					</table>
				</div>
				<div id="csv-preview-warnings" class="preview-warnings" style="display: none;"></div>
			</div>
		</div>
		<div class="modal-footer">
			<button class="btn btn-secondary" onclick="closeCSVImportModal()">Cancel</button>
			<button class="btn btn-primary" id="csv-import-btn" onclick="confirmCSVImport()" disabled>
				<span id="csv-import-btn-text">Import</span>
			</button>
		</div>
	</div>
</div>

<!-- Participant Modal -->
<div id="participant-modal" class="modal-overlay" style="display: none;" onclick="if(event.target === this) closeParticipantModal()">


	<div class="modal">
		<div class="modal-header">
			<h3 id="participant-modal-title" class="modal-title">Add Participant</h3>
			<button class="modal-close" onclick="closeParticipantModal()">&times;</button>
		</div>
		<div class="modal-body">
			<form id="participant-form" onsubmit="saveParticipant(event)">
				<input type="hidden" id="participant-id">
				<div class="form-group">
					<label for="participant-email" class="form-label">Email *</label>
					<input type="email" id="participant-email" class="form-input" required>
				</div>
				<div class="form-group">
					<label for="participant-name" class="form-label">Captain Name *</label>
					<input type="text" id="participant-name" class="form-input" required>
				</div>
				<div class="form-group">
					<label for="participant-team" class="form-label">Team Name *</label>
					<input type="text" id="participant-team" class="form-input" required>
				</div>
				<div class="form-group">
					<label for="participant-discord" class="form-label">Discord Username</label>
					<input type="text" id="participant-discord" class="form-input" placeholder="username#0000">
				</div>
			</form>
		</div>
		<div class="modal-footer">
			<button class="btn btn-secondary" onclick="closeParticipantModal()">Cancel</button>
			<button class="btn btn-primary" onclick="saveParticipant(event)">Save</button>
		</div>
	</div>
</div>

<!-- Schedule Modal -->
<div id="schedule-modal" class="modal-overlay" style="display: none;" onclick="if(event.target === this) closeScheduleModal()">


	<div class="modal">
		<div class="modal-header">
			<h3 id="schedule-modal-title" class="modal-title">Add Schedule</h3>
			<button class="modal-close" onclick="closeScheduleModal()">&times;</button>
		</div>
		<div class="modal-body">
			<form id="schedule-form" onsubmit="saveSchedule(event)">
				<input type="hidden" id="schedule-id">
				<div class="form-group">
					<label for="schedule-match-id" class="form-label">Match ID *</label>
					<input type="number" id="schedule-match-id" class="form-input" required>
				</div>
				<div class="form-group" id="schedule-teams-container" style="display: none;">
					<label class="form-label">Teams</label>
					<div id="schedule-teams-display" class="form-input" style="background: var(--bg-secondary); border-color: transparent; font-weight: 600;"></div>
				</div>
				<div class="form-group">
					<label for="schedule-time" class="form-label">Scheduled Time *</label>
					<input type="datetime-local" id="schedule-time" class="form-input" required>
				</div>
				<div class="form-group">
					<label for="schedule-timezone" class="form-label">Timezone</label>
					<select id="schedule-timezone" class="form-input" style="appearance: auto;">
						<option value="">Select a timezone...</option>
					</select>
				</div>
			</form>
		</div>
		<div class="modal-footer">
			<button class="btn btn-secondary" onclick="closeScheduleModal()">Cancel</button>
			<button class="btn btn-primary" onclick="saveSchedule(event)">Save</button>
		</div>
	</div>
</div>

<!-- Start Round Modal -->
<div id="start-round-modal" class="modal-overlay" style="display: none;" onclick="if(event.target === this) closeStartRoundModal()">
	<div class="modal">
		<div class="modal-header">
			<h3 class="modal-title">Start Round</h3>
			<button class="modal-close" onclick="closeStartRoundModal()">&times;</button>
		</div>
		<div class="modal-body">
			<form id="start-round-form">
				<div class="form-group">
					<label for="round-select" class="form-label">Round Number *</label>
					<select id="round-select" class="form-input" required onchange="onRoundChange()">
						<option value="">Loading rounds...</option>
					</select>
					<p class="help-text">Select a round from imported schedules</p>
				</div>
				<div class="form-group">
					<label for="channel-select" class="form-label">Discord Channel *</label>
					<select id="channel-select" class="form-input" required>
						<option value="">Loading channels...</option>
					</select>
					<p class="help-text">Text channel where match threads will be created</p>
				</div>

				<!-- Preview Section -->
				<div id="round-preview-section" style="display: none;">
					<h4 style="margin: 20px 0 12px; font-size: 15px; font-weight: 600; color: var(--text-primary);">
						Preview (<span id="preview-match-count">0</span> matches)
					</h4>
					<div id="preview-warnings" style="display: none;" class="preview-warnings"></div>
					<div class="table-container table-preview">
						<table class="table table-sm">
							<thead>
								<tr>
									<th>Match</th>
									<th>Scheduled Time</th>
									<th>Status</th>
								</tr>
							</thead>
							<tbody id="preview-tbody">
							</tbody>
						</table>
					</div>
				</div>
			</form>
		</div>
		<div class="modal-footer">
			<button class="btn btn-secondary" onclick="closeStartRoundModal()">Cancel</button>
			<button class="btn btn-primary" id="btn-confirm-start-round" onclick="confirmStartRound()" disabled>
				Start Round
			</button>
		</div>
	</div>
</div>

<!-- CSV Format Guide Modal - Participants -->
<div id="csv-format-participants-modal" class="modal-overlay" style="display: none;" onclick="if(event.target === this) closeCSVFormatModal()">
	<div class="modal modal-large">
		<div class="modal-header">
			<h3 class="modal-title">CSV Format Guide - Participants</h3>
			<button class="modal-close" onclick="closeCSVFormatModal()">&times;</button>
		</div>
		<div class="modal-body">
			<div class="csv-format-guide">
				<h4>Required Columns</h4>
				<p>Your CSV file must include the following columns in the header row:</p>
				<table class="table table-sm">
					<thead>
						<tr>
							<th>Column</th>
							<th>Description</th>
							<th>Required</th>
						</tr>
					</thead>
					<tbody>
						<tr>
							<td><code>email</code></td>
							<td>Captain's email address</td>
							<td>Yes</td>
						</tr>
						<tr>
							<td><code>name</code></td>
							<td>Captain's full name</td>
							<td>Yes</td>
						</tr>
						<tr>
							<td><code>team</code></td>
							<td>Team name</td>
							<td>Yes</td>
						</tr>
						<tr>
							<td><code>discord</code></td>
							<td>Discord username (e.g., username#0000)</td>
							<td>No</td>
						</tr>
					</tbody>
				</table>

				<h4 style="margin-top: 24px;">Example CSV</h4>
				<pre style="background: var(--bg-secondary); padding: 16px; border-radius: var(--radius-sm); overflow-x: auto;">email,name,team,discord
captain1@example.com,John Doe,Team Alpha,johndoe#1234
captain2@example.com,Jane Smith,Team Beta,janesmith#5678
captain3@example.com,Bob Wilson,Team Gamma,</pre>

				<h4 style="margin-top: 24px;">Download Template</h4>
				<p>Download a blank template to get started:</p>
				<button class="btn btn-secondary" onclick="downloadParticipantTemplate()">
					<span class="btn-icon"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg></span>
					Download Participant Template
				</button>
			</div>
		</div>
		<div class="modal-footer">
			<button class="btn btn-primary" onclick="closeCSVFormatModal()">Got it</button>
		</div>
	</div>
</div>

<!-- CSV Format Guide Modal - Schedules -->
<div id="csv-format-schedules-modal" class="modal-overlay" style="display: none;" onclick="if(event.target === this) closeCSVFormatModal()">
	<div class="modal modal-large">
		<div class="modal-header">
			<h3 class="modal-title">CSV Format Guide - Schedules</h3>
			<button class="modal-close" onclick="closeCSVFormatModal()">&times;</button>
		</div>
		<div class="modal-body">
			<div class="csv-format-guide">
				<h4>Required Columns</h4>
				<p>Your CSV file must include the following columns in the header row:</p>
				<table class="table table-sm">
					<thead>
						<tr>
							<th>Column</th>
							<th>Description</th>
							<th>Required</th>
						</tr>
					</thead>
					<tbody>
						<tr>
							<td><code>match_id</code></td>
							<td>Unique match identifier</td>
							<td>Yes</td>
						</tr>
						<tr>
							<td><code>scheduled_time</code></td>
							<td>Scheduled time in YYYY-MM-DD HH:MM:SS format</td>
							<td>Yes</td>
						</tr>
						<tr>
							<td><code>timezone</code></td>
							<td>Timezone abbreviation (e.g., IST, UTC, EST). Defaults to UTC if not provided.</td>
							<td>No</td>
						</tr>
					</tbody>
				</table>

				<h4 style="margin-top: 24px;">Optional Columns (for reference)</h4>
				<p>These columns are optional but helpful for identifying matches. They are ignored during import:</p>
				<table class="table table-sm">
					<thead>
						<tr>
							<th>Column</th>
							<th>Description</th>
							<th>Required</th>
						</tr>
					</thead>
					<tbody>
						<tr>
							<td><code>round</code></td>
							<td>Round number</td>
							<td>No</td>
						</tr>
						<tr>
							<td><code>teams</code></td>
							<td>Team names (e.g., "Team A vs Team B")</td>
							<td>No</td>
						</tr>
					</tbody>
				</table>

				<h4 style="margin-top: 24px;">Existing Schedules</h4>
				<p>Here are your current schedules. Copy this data, update the times, and import it back:</p>

				<div id="existing-schedules-loading" style="text-align: center; padding: 20px; color: var(--text-secondary);">
					<div class="spinner"></div> Loading existing schedules...
				</div>

				<div id="existing-schedules-content" style="display: none;">
					<div style="display: flex; gap: 8px; margin-bottom: 12px;">
						<button class="btn btn-secondary btn-sm" onclick="copyScheduleCSV()">
							<span class="btn-icon"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg></span>
							Copy CSV
						</button>
						<button class="btn btn-primary btn-sm" onclick="downloadScheduleTemplate()">
							<span class="btn-icon"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg></span>
							Download CSV
						</button>
					</div>
					<pre id="existing-schedules-csv" style="background: var(--bg-secondary); padding: 16px; border-radius: var(--radius-sm); overflow-x: auto; max-height: 300px; overflow-y: auto;"></pre>
				</div>

				<div id="existing-schedules-empty" style="display: none; padding: 20px; background: var(--bg-secondary); border-radius: var(--radius-sm); text-align: center; color: var(--text-secondary);">
					<p>No schedules found. Download a blank template to get started:</p>
					<button class="btn btn-secondary" onclick="downloadBlankScheduleTemplate()">
						<span class="btn-icon"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg></span>
						Download Blank Template
					</button>
				</div>
			</div>
		</div>
		<div class="modal-footer">
			<button class="btn btn-primary" onclick="closeCSVFormatModal()">Got it</button>
		</div>
	</div>
</div>

<style>
.tournament-detail-page {
	max-width: 1200px;
}

.page-header {
	display: flex;
	justify-content: space-between;
