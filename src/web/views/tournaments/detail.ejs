let editingScheduleId = null;

function openScheduleModal(schedule = null) {
	editingScheduleId = schedule ? schedule.id : null;

	const title = schedule ? 'Edit Schedule' : 'Add Schedule';
	document.getElementById('schedule-modal-title').textContent = title;

	if (schedule) {
		document.getElementById('schedule-id').value = schedule.id;
		document.getElementById('schedule-match-id').value = schedule.matchId;
		
		// Set teams display
		const teamsContainer = document.getElementById('schedule-teams-container');
		const teamsDisplay = document.getElementById('schedule-teams-display');
		if (schedule.player1Name && schedule.player2Name) {
			teamsDisplay.textContent = `${schedule.player1Name} vs ${schedule.player2Name}`;
			teamsContainer.style.display = 'block';
		} else {
			teamsContainer.style.display = 'none';
		}

		// Convert datetime to datetime-local format
		const date = new Date(schedule.scheduledTime);
		date.setMinutes(date.getMinutes() - date.getTimezoneOffset());
		document.getElementById('schedule-time').value = date.toISOString().slice(0, 16);
	} else {
		document.getElementById('schedule-form').reset();
		document.getElementById('schedule-id').value = '';
		document.getElementById('schedule-teams-container').style.display = 'none';
	}

	document.getElementById('schedule-modal').style.display = 'flex';
}

function closeScheduleModal() {
	document.getElementById('schedule-modal').style.display = 'none';
	editingScheduleId = null;
}

async function saveSchedule(event) {
	event.preventDefault();

	const matchId = document.getElementById('schedule-match-id').value;
	const scheduledTime = document.getElementById('schedule-time').value;
	const timezone = document.getElementById('schedule-timezone').value.trim();

	if (!matchId || !scheduledTime) {
		Dot.Toast.error('Please fill in all required fields');
		return;
	}

	try {
		const body = { matchId, scheduledTime, timezone: timezone || undefined };

		if (editingScheduleId) {
			await Dot.API.put(`/api/tournaments/${tournamentId}/schedules/${editingScheduleId}`, body);
			Dot.Toast.success('Schedule updated successfully');
		} else {
			await Dot.API.post(`/api/tournaments/${tournamentId}/schedules`, body);
			Dot.Toast.success('Schedule added successfully');
		}

		await loadTournamentData();
		closeScheduleModal();

	} catch (error) {
		console.error('Failed to save schedule:', error);
		const errorMsg = error.response?.data?.error || 'Failed to save schedule';
		Dot.Toast.error(errorMsg);
	}
}

async function deleteSchedule(id) {
	Dot.Modal.confirm(
		'Delete Schedule',
		'Are you sure you want to delete this schedule?',
		async () => {
			try {
				await Dot.API.delete(`/api/tournaments/${tournamentId}/schedules/${id}`);
				Dot.Toast.success('Schedule deleted successfully');
				await loadTournamentData();
			} catch (error) {
				console.error('Failed to delete schedule:', error);
				Dot.Toast.error('Failed to delete schedule');
			}
		}
	);
}

