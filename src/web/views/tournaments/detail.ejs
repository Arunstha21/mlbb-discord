<%- contentFor('script') %>
<script>
const tournamentId = "<%= tournamentId %>";

document.addEventListener('DOMContentLoaded', () => {
	const tzSelect = document.getElementById('schedule-timezone');
	if (tzSelect && Intl.supportedValuesOf) {
		const timezones = Intl.supportedValuesOf('timeZone');
		const localTz = Intl.DateTimeFormat().resolvedOptions().timeZone;
		
		timezones.forEach(tz => {
			const option = document.createElement('option');
			option.value = tz;
			option.textContent = tz.replace(/_/g, ' ');
			if (tz === localTz) {
				option.selected = true;
			}
			tzSelect.appendChild(option);
		});
	}

	// Handle tab persistence
	const hash = window.location.hash.replace('#', '');
	if (hash === 'participants' || hash === 'schedules') {
		switchTab(hash);
	}
});

async function loadTournamentData() {
	try {
		const [tRes, pRes, sRes] = await Promise.all([
			Dot.API.get(`/api/tournaments/${tournamentId}`),
			Dot.API.get(`/api/tournaments/${tournamentId}/participants`),
			Dot.API.get(`/api/tournaments/${tournamentId}/schedules`)
		]);

		renderInfo(tRes.data);
		renderParticipants(pRes.data || []);
		renderSchedules(sRes.data || []);
	} catch (error) {
		console.error("Failed to load tournament data:", error);
		Dot.Toast.error("Failed to load tournament data");
	}
}

function renderInfo(t) {
	document.getElementById('t-name').textContent = t.name || tournamentId;
	
	// Status
	const statusEl = document.getElementById('t-status-badge');
	const status = t.status || 'unknown';
	statusEl.textContent = status;
	statusEl.className = `badge badge-${getStatusBadgeClass(status)}`;

	document.getElementById('t-format').textContent = t.format || 'Unknown Format';

	// Info Cards
	document.getElementById('t-server').textContent = t.server || '—';

	const cap = t.participantLimit ? `${t.enrolledCount || 0} / ${t.participantLimit}` : `${t.enrolledCount || 0} / ∞`;
	document.getElementById('t-capacity').textContent = cap;

	// Verification Stats
	document.getElementById('t-verified-count').textContent = t.verifiedCount || 0;
	document.getElementById('t-unverified-count').textContent = t.unverifiedCount || 0;

	// Tab Counts
	document.getElementById('t-p-count').textContent = t.enrolledCount || 0;
	document.getElementById('t-s-count').textContent = t.scheduledCount || 0;
}

function getStatusBadgeClass(status) {
	switch (status) {
		case 'preparing': return 'warning';
		case 'in progress': return 'info';
		case 'complete': return 'success';
		default: return 'secondary';
	}
}

function renderParticipants(participants) {
	const tbody = document.getElementById('participants-body');
	
	if (!participants.length) {
		tbody.innerHTML = `<tr><td colspan="5" class="empty-state"><div class="empty-state-text">No participants enrolled</div></td></tr>`;
		return;
	}

	tbody.innerHTML = participants.map(p => `
		<tr>
			<td><strong>${escapeHtml(p.team)}</strong></td>
			<td>${escapeHtml(p.name)}</td>
			<td>${p.discordUsername ? escapeHtml(p.discordUsername) : '<span style="color:var(--text-secondary)">—</span>'}</td>
			<td>${p.challongeId || '<span style="color:var(--text-secondary)">—</span>'}</td>
			<td><span class="badge badge-${p.verified ? 'success' : 'warning'}">${p.verified ? 'Verified' : 'Unverified'}</span></td>
		</tr>
	`).join('');
}

function renderSchedules(schedules) {
	const tbody = document.getElementById('schedules-body');
	
	if (!schedules.length) {
		tbody.innerHTML = `<tr><td colspan="7" class="empty-state"><div class="empty-state-text">No matches scheduled</div></td></tr>`;
		return;
	}

	tbody.innerHTML = schedules.map(s => {
		const dateObj = new Date(s.scheduledTime);
		let formattedDate = s.scheduledTime;
		
		if (!isNaN(dateObj.getTime())) {
			if (dateObj.getFullYear() > 2090) {
				formattedDate = '<span style="color:var(--text-secondary)">Not set</span>';
			} else {
				formattedDate = dateObj.toLocaleString(undefined, { 
					weekday: 'short', month: 'short', day: 'numeric', 
					hour: '2-digit', minute: '2-digit' 
				});
			}
		}
		
		return `
		<tr>
			<td><strong>#${s.matchId}</strong></td>
			<td>Round ${s.round || '?'}</td>
			<td>${formattedDate}</td>
			<td>${s.threadId || '<span style="color:var(--text-secondary)">—</span>'}</td>
			<td><span class="${s.notified ? 'text-success' : 'text-secondary'}">${s.notified ? 'Yes' : 'No'}</span></td>
		</tr>
		`;
	}).join('');
}

function switchTab(tabId) {
	document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active'));
	document.querySelectorAll('.tab-pane').forEach(pane => pane.classList.remove('active'));
	
	const btn = document.querySelector(`.tab-btn[data-tab="${tabId}"]`);
	const pane = document.getElementById(`pane-${tabId}`);
	
	if (btn && pane) {
		btn.classList.add('active');
		pane.classList.add('active');
		// Update URL hash without jumping
		history.replaceState(null, null, `#${tabId}`);
	}
}

async function syncTournament() {
	try {
		const btn = document.getElementById('btn-sync');
		btn.disabled = true;
		btn.textContent = 'Syncing...';

		const response = await Dot.API.post(`/api/tournaments/${tournamentId}/sync`);
		const data = response.data;

		let message = 'Tournament synced successfully!';
		if (data.matchedPlayers !== undefined) {
			message += ` Matched ${data.matchedPlayers} participants.`;
		}
		if (data.addedSchedules !== undefined) {
			message += ` Added ${data.addedSchedules} new schedules.`;
		}
		if (data.skippedSchedules !== undefined && data.skippedSchedules > 0) {
			message += ` Skipped ${data.skippedSchedules} existing schedules.`;
		}

		Dot.Toast.success(message);

		// Reload data
		await loadTournamentData();
	} catch (error) {
		console.error('Failed to sync tournament:', error);
		Dot.Toast.error('Failed to sync tournament');
	} finally {
		const btn = document.getElementById('btn-sync');
		btn.disabled = false;
		btn.textContent = 'Sync from Challonge';
	}
}

function escapeHtml(text) {
	if (!text) return '';
	const div = document.createElement('div');
	div.textContent = text;
	return div.innerHTML;
}



// ============================================
// CSV Import Functions
// ============================================

let currentCSVImportType = null;
let currentCSVData = null;
let parsedCSVRows = [];

function openCSVImportModal(type) {
	currentCSVImportType = type;
	currentCSVData = null;
	parsedCSVRows = [];

	// Reset modal state
	clearCSVFile();
	document.getElementById('csv-preview-section').style.display = 'none';
	document.getElementById('csv-options-section').style.display = 'none';
	document.getElementById('csv-import-btn').disabled = true;

	// Set title
	const title = type === 'participants' ? 'Import Participants from CSV' : 'Import Schedules from CSV';
	document.getElementById('csv-modal-title').textContent = title;

	// Show/hide Challonge option
	document.getElementById('csv-options-section').style.display = type === 'participants' ? 'block' : 'none';

	// Show modal
	document.getElementById('csv-import-modal').style.display = 'flex';

	// Setup drag and drop
	setupDropzone();
}

function closeCSVImportModal() {
	document.getElementById('csv-import-modal').style.display = 'none';
	currentCSVImportType = null;
	currentCSVData = null;
	parsedCSVRows = [];
}

function setupDropzone() {
	const dropzone = document.getElementById('csv-dropzone');

	dropzone.onclick = () => document.getElementById('csv-file-input').click();

	dropzone.ondragover = (e) => {
		e.preventDefault();
		dropzone.classList.add('drag-over');
	};

	dropzone.ondragleave = () => {
		dropzone.classList.remove('drag-over');
	};

	dropzone.ondrop = (e) => {
		e.preventDefault();
		dropzone.classList.remove('drag-over');

		const files = e.dataTransfer.files;
		if (files.length > 0) {
			processCSVFile(files[0]);
		}
	};
}

function handleCSVFileSelect(event) {
	const file = event.target.files[0];
	if (file) {
		processCSVFile(file);
	}
}

function processCSVFile(file) {
	if (!file.name.endsWith('.csv')) {
		Dot.Toast.error('Please select a CSV file');
		return;
	}

	const reader = new FileReader();
	reader.onload = (e) => {
		currentCSVData = e.target.result;
		displayFileInfo(file);
		parseAndPreviewCSV();
	};
	reader.readAsText(file);
}

function displayFileInfo(file) {
	document.getElementById('csv-dropzone').style.display = 'none';
	document.getElementById('csv-file-info').style.display = 'block';
	document.getElementById('csv-file-name').textContent = file.name;
	document.getElementById('csv-file-size').textContent = formatFileSize(file.size);
}

function clearCSVFile() {
	currentCSVData = null;
	parsedCSVRows = [];
	document.getElementById('csv-file-input').value = '';
	document.getElementById('csv-dropzone').style.display = 'block';
	document.getElementById('csv-file-info').style.display = 'none';
	document.getElementById('csv-preview-section').style.display = 'none';
	document.getElementById('csv-import-btn').disabled = true;
}

function formatFileSize(bytes) {
	if (bytes < 1024) return bytes + ' B';
	if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB';
	return (bytes / (1024 * 1024)).toFixed(1) + ' MB';
}

function parseAndPreviewCSV() {
	if (!currentCSVData) return;

	const lines = currentCSVData.trim().split('\n').map(l => l.trim()).filter(l => l.length > 0);

	if (lines.length < 2) {
		Dot.Toast.error('CSV must have at least a header and one data row');
		return;
	}

	// Parse header
	const headers = parseCSVRow(lines[0]);
	parsedCSVRows = [];

	// Parse data rows
	for (let i = 1; i < lines.length; i++) {
		const columns = parseCSVRow(lines[i]);
		parsedCSVRows.push(columns);
	}

	// Validate headers
	const expectedCols = currentCSVImportType === 'participants'
		? ['email', 'name', 'team']
		: ['match_id', 'scheduled_time'];

	const headersLower = headers.map(h => h.toLowerCase());
	const missingCols = expectedCols.filter(col => !headersLower.some(h => h.includes(col)));

	if (missingCols.length > 0) {
		showPreviewWarning(`Missing required columns: ${missingCols.join(', ')}`);
	} else {
		hidePreviewWarning();
	}

	// Render preview
	renderCSVPreview(headers);

	// Show options and enable import
	if (currentCSVImportType === 'participants') {
		document.getElementById('csv-options-section').style.display = 'block';
	}
	document.getElementById('csv-import-btn').disabled = false;
}

function parseCSVRow(row) {
	const result = [];
	let current = '';
	let inQuotes = false;

	for (let i = 0; i < row.length; i++) {
		const char = row[i];

		if (char === '"') {
			inQuotes = !inQuotes;
		} else if (char === ',' && !inQuotes) {
			result.push(current.trim());
			current = '';
		} else {
			current += char;
		}
	}
	result.push(current.trim());

	return result;
}

function renderCSVPreview(headers) {
	const thead = document.getElementById('csv-preview-thead');
	const tbody = document.getElementById('csv-preview-tbody');

	// Render header
	thead.innerHTML = '<tr>' + headers.map(h => `<th>${escapeHtml(h)}</th>`).join('') + '</tr>';

	// Render rows (max 10 for preview)
	const previewRows = parsedCSVRows.slice(0, 10);
	tbody.innerHTML = previewRows.map(row => {
		return '<tr>' + row.map(cell => `<td>${escapeHtml(cell)}</td>`).join('') + '</tr>';
	}).join('');

	// Update count
	document.getElementById('csv-preview-count').textContent = parsedCSVRows.length;

	// Show preview section
	document.getElementById('csv-preview-section').style.display = 'block';
}

function showPreviewWarning(message) {
	const warningsEl = document.getElementById('csv-preview-warnings');
	warningsEl.textContent = '⚠️ ' + message;
	warningsEl.style.display = 'block';
}

function hidePreviewWarning() {
	document.getElementById('csv-preview-warnings').style.display = 'none';
}

async function confirmCSVImport() {
	if (!currentCSVData || !currentCSVImportType) return;

	const btn = document.getElementById('csv-import-btn');
	const btnText = document.getElementById('csv-import-btn-text');
	btn.disabled = true;
	btnText.textContent = 'Importing...';

	try {
		const endpoint = `/api/tournaments/${tournamentId}/${currentCSVImportType}/import`;
		const body = { csv: currentCSVData };

		if (currentCSVImportType === 'participants') {
			body.registerToChallonge = document.getElementById('csv-register-challonge').checked;
		}

		const response = await Dot.API.post(endpoint, body);

		const data = response.data;
		let message = `Import complete!`;
		if (data.added) message += ` Added: ${data.added}.`;
		if (data.updated) message += ` Updated: ${data.updated}.`;
		if (data.errors?.length) message += ` Errors: ${data.totalErrors || data.errors.length}.`;

		Dot.Toast.success(message);

		// Reload data
		await loadTournamentData();

		// Close modal
		closeCSVImportModal();

	} catch (error) {
		console.error('CSV import failed:', error);
		const errorMsg = error.response?.data?.error || 'Import failed. Please check your CSV format.';
		Dot.Toast.error(errorMsg);
	} finally {
		btn.disabled = false;
		btnText.textContent = 'Import';
	}
}

// ============================================
// Participant Modal Functions
// ============================================

let editingParticipantId = null;

function openParticipantModal(participant = null) {
	editingParticipantId = participant ? participant.id : null;

	const title = participant ? 'Edit Participant' : 'Add Participant';
	document.getElementById('participant-modal-title').textContent = title;

	if (participant) {
		document.getElementById('participant-id').value = participant.id;
		document.getElementById('participant-email').value = participant.email;
		document.getElementById('participant-name').value = participant.name;
		document.getElementById('participant-team').value = participant.team;
		document.getElementById('participant-discord').value = participant.discordUsername || '';
	} else {
		document.getElementById('participant-form').reset();
		document.getElementById('participant-id').value = '';
	}

	document.getElementById('participant-modal').style.display = 'flex';
}

function closeParticipantModal() {
	document.getElementById('participant-modal').style.display = 'none';
	editingParticipantId = null;
}

async function saveParticipant(event) {
	event.preventDefault();

	const email = document.getElementById('participant-email').value.trim();
	const name = document.getElementById('participant-name').value.trim();
	const team = document.getElementById('participant-team').value.trim();
	const discordUsername = document.getElementById('participant-discord').value.trim();

	if (!email || !name || !team) {
		Dot.Toast.error('Please fill in all required fields');
		return;
	}

	try {
		if (editingParticipantId) {
			// Update
			await Dot.API.put(`/api/tournaments/${tournamentId}/participants/${editingParticipantId}`, {
				name, team, discordUsername
			});
			Dot.Toast.success('Participant updated successfully');
		} else {
			// Create
			await Dot.API.post(`/api/tournaments/${tournamentId}/participants`, {
				email, name, team, discordUsername
			});
			Dot.Toast.success('Participant added successfully');
		}

		await loadTournamentData();
		closeParticipantModal();

	} catch (error) {
		console.error('Failed to save participant:', error);
		const errorMsg = error.response?.data?.error || 'Failed to save participant';
		Dot.Toast.error(errorMsg);
	}
}

async function deleteParticipant(id) {
	Dot.Modal.confirm(
		'Delete Participant',
		'Are you sure you want to delete this participant?',
		async () => {
			try {
				await Dot.API.delete(`/api/tournaments/${tournamentId}/participants/${id}`);
				Dot.Toast.success('Participant deleted successfully');
				await loadTournamentData();
			} catch (error) {
				console.error('Failed to delete participant:', error);
				Dot.Toast.error('Failed to delete participant');
			}
		}
	);
}

