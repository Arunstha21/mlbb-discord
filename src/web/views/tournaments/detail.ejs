// ============================================
// CSV Template Download Functions
// ============================================

function downloadParticipantTemplate() {
	// Use server-side download endpoint (works reliably in Electron)
	window.location.href = `/api/tournaments/${tournamentId}/participants/download-template`;
	Dot.Toast.success('Downloading participant template...');
}

async function downloadScheduleTemplate() {
	try {
		// Use server-side download endpoint (works reliably in Electron)
		window.location.href = `/api/tournaments/${tournamentId}/schedules/download`;
		Dot.Toast.success('Downloading schedule template...');
	} catch (error) {
		console.error('Failed to download schedule template:', error);
		Dot.Toast.error('Failed to download template.');
	}
}

function downloadBlankScheduleTemplate() {
	// Use server-side download endpoint (works reliably in Electron)
	window.location.href = `/api/tournaments/${tournamentId}/schedules/download-blank`;
	Dot.Toast.success('Downloading blank schedule template...');
}

function downloadCSV(content, filename) {
	const blob = new Blob([content], { type: 'text/csv;charset=utf-8;' });
	const url = URL.createObjectURL(blob);

	// Method 1: Try location.href approach (works in Electron)
	try {
		const a = document.createElement('a');
		a.href = url;
		a.download = filename;
		a.style.display = 'none';

		// For Electron/Chromium, we need to append to DOM and use click
		document.body.appendChild(a);

		// Try click first
		a.click();

		// If that doesn't trigger, try dispatchEvent
		setTimeout(() => {
			if (!document.hasFocus()) {
				// Download dialog opened, cleanup will happen after
				setTimeout(() => {
					document.body.removeChild(a);
					URL.revokeObjectURL(url);
				}, 1000);
			} else {
				// Try alternative: window.open or location.href
				window.open(url, '_blank');
				setTimeout(() => {
					document.body.removeChild(a);
					URL.revokeObjectURL(url);
				}, 100);
			}
		}, 100);

		Dot.Toast.success(`Downloading ${filename}...`);
		return;
	} catch (e) {
		console.error('Download method 1 failed:', e);
	}

	// Method 2: Fallback to opening in new tab
	try {
		window.open(url, '_blank');
		Dot.Toast.success(`Opening ${filename} in new tab...`);
		setTimeout(() => URL.revokeObjectURL(url), 1000);
		return;
	} catch (e) {
		console.error('Download method 2 failed:', e);
	}

	// Method 3: Last resort - location.href
	try {
		const originalLocation = window.location.href;
		window.location.href = url;
		setTimeout(() => {
			window.location.href = originalLocation;
			URL.revokeObjectURL(url);
		}, 100);
		Dot.Toast.success(`Downloading ${filename}...`);
	} catch (e) {
		console.error('All download methods failed:', e);
		Dot.Toast.error('Download failed. Please copy the CSV content instead.');
		URL.revokeObjectURL(url);
	}
}

// Store existing schedules CSV for copying
let existingSchedulesCSV = '';

async function loadExistingSchedulesForModal() {
	// Reset modal state
	document.getElementById('existing-schedules-loading').style.display = 'block';
	document.getElementById('existing-schedules-content').style.display = 'none';
	document.getElementById('existing-schedules-empty').style.display = 'none';

	try {
		// Fetch existing schedules
		const response = await Dot.API.get(`/api/tournaments/${tournamentId}/schedules`);
		const schedules = response.data.data || response.data;

		if (!schedules || schedules.length === 0) {
			document.getElementById('existing-schedules-loading').style.display = 'none';
			document.getElementById('existing-schedules-empty').style.display = 'block';
			existingSchedulesCSV = '';
			return;
		}

		// Create CSV with existing data including round and teams for reference
		const headers = 'match_id,scheduled_time,timezone,round,teams';
		const rows = schedules.map(s => {
			const date = s.scheduledTime ? new Date(s.scheduledTime) : new Date();
			// Format: YYYY-MM-DD HH:MM:SS
			const formattedTime = date.getFullYear() + '-' +
				String(date.getMonth() + 1).padStart(2, '0') + '-' +
				String(date.getDate()).padStart(2, '0') + ' ' +
				String(date.getHours()).padStart(2, '0') + ':' +
				String(date.getMinutes()).padStart(2, '0') + ':' +
				String(date.getSeconds()).padStart(2, '0');
			// Use UTC as default timezone (organizer can change it)
			const round = s.round || '';
			const teams = s.player1Name && s.player2Name ? `${s.player1Name} vs ${s.player2Name}` : '';
			return `${s.matchId},${formattedTime},UTC,${round},"${teams}"`;
		});

		existingSchedulesCSV = [headers, ...rows].join('\n');

		// Display CSV in modal
		document.getElementById('existing-schedules-csv').textContent = existingSchedulesCSV;
		document.getElementById('existing-schedules-loading').style.display = 'none';
		document.getElementById('existing-schedules-content').style.display = 'block';

	} catch (error) {
		console.error('Failed to load existing schedules:', error);
		document.getElementById('existing-schedules-loading').style.display = 'none';
		document.getElementById('existing-schedules-empty').style.display = 'block';
		existingSchedulesCSV = '';
	}
}

function copyScheduleCSV() {
	if (!existingSchedulesCSV) {
		Dot.Toast.error('No schedules to copy');
		return;
	}

	navigator.clipboard.writeText(existingSchedulesCSV).then(() => {
		Dot.Toast.success('CSV copied to clipboard!');
	}).catch(() => {
		Dot.Toast.error('Failed to copy to clipboard');
	});
}
